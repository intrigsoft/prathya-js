{
  "name": "@intrigsoft/pratya-core",
  "version": "0.0.4",
  "description": "Requirement coverage and traceability engine for Contract-Driven Development",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "js-yaml": "^4.1.0",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@intrigsoft/pratya-vitest": "workspace:*",
    "@vitest/coverage-v8": "^1.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mustache": "^4.2.5",
    "@types/node": "^20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0"
}
