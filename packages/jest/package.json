{
  "name": "@pratya/jest",
  "version": "0.1.0",
  "description": "Jest integration for Pratya requirement coverage",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./reporter": {
      "types": "./dist/reporter.d.ts",
      "import": "./dist/reporter.js",
      "require": "./dist/reporter.cjs"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.js",
      "require": "./dist/setup.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pratya/core": "workspace:*"
  },
  "devDependencies": {
    "@jest/reporters": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0"
  },
  "peerDependencies": {
    "jest": ">=29.0.0"
  },
  "license": "Apache-2.0"
}
